# Google AI Studio API Key — https://aistudio.google.com/
GOOGLE_API_KEY=your_google_ai_key_here

# Model choice (gemini-2.0-flash = fast/cheap, gemini-1.5-pro = higher quality)
GOOGLE_MODEL=gemini-2.0-flash

# Authentication — change AUTH_SECRET to a long random string!
AUTH_SECRET=change-this-to-a-long-random-string-in-production
AUTH_PASSWORD=your_dashboard_password

# Database directory (optional)
# Local dev: omit this — defaults to ./data/powned.db
# Railway: set DATA_DIR to your volume mount path, e.g. /data
# DATA_DIR=/data
